<Window x:Class="SnaggingTracker.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:SnaggingTracker.ViewModels"
        xmlns:helpers="clr-namespace:SnaggingTracker.Helpers"
        xmlns:conv="clr-namespace:SnaggingTracker.Converters"
        mc:Ignorable="d"
        Title="Site Issue &amp; Snagging Tracker"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Calibri">

    <Window.Resources>
        <!-- Local converters for inline use -->
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:EnumDisplayConverter      x:Key="EnumDisp"/>
        <conv:PriorityToColorConverter  x:Key="PrioColor"/>
        <conv:StatusToColorConverter    x:Key="StatColor"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
    </Window.Resources>

    <!-- Trigger load command when window is loaded -->
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadIssuesCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Top navbar -->
            <RowDefinition Height="Auto"/> <!-- Stats bar -->
            <RowDefinition Height="Auto"/> <!-- Toolbar / filter bar -->
            <RowDefinition Height="*"/>    <!-- Main content -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             ROW 0 — TOP NAVBAR
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource NavyBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" Foreground="{StaticResource AmberBrush}" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="SNAGGING TRACKER" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" CharacterSpacing="60"/>
                    <Border Background="#1B4F72" CornerRadius="3" Padding="6,2" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="QA/QC" Foreground="{StaticResource AmberBrush}" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <!-- Export buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="📊  Export Full Report"
                            Command="{Binding ExportFullReportCommand}"
                            Style="{StaticResource TealButton}"
                            Margin="0,0,8,0" Padding="12,6" FontSize="12"/>
                    <Button Content="📋  Snag List"
                            Command="{Binding ExportSnagListCommand}"
                            Style="{StaticResource GhostButton}"
                            Foreground="White" BorderBrush="#2E4057"
                            Margin="0,0,8,0" Padding="12,6" FontSize="12"/>
                    <Button Content="👷  Contractor Report"
                            Command="{Binding ExportContractorCommand}"
                            Style="{StaticResource GhostButton}"
                            Foreground="White" BorderBrush="#2E4057"
                            Padding="12,6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 1 — STATS BAR
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel Orientation="Horizontal">

                <!-- Total -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL ISSUES" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource NavyBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Open -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="OPEN" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OpenCount}" FontSize="28" FontWeight="Bold" Foreground="#C0392B"/>
                    </StackPanel>
                </Border>

                <!-- In Progress -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="IN PROGRESS" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InProgressCount}" FontSize="28" FontWeight="Bold" Foreground="#2174AE"/>
                    </StackPanel>
                </Border>

                <!-- Closed -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="CLOSED" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ClosedCount}" FontSize="28" FontWeight="Bold" Foreground="#1E8449"/>
                    </StackPanel>
                </Border>

                <!-- Closure Rate -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0" Background="{StaticResource NavyBrush}">
                    <StackPanel>
                        <TextBlock Text="CLOSURE RATE" Style="{StaticResource Caption}" FontWeight="SemiBold" Foreground="#90A4AE"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ClosureRate}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AmberBrush}"/>
                            <TextBlock Text="%" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AmberBrush}" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 2 — TOOLBAR / FILTER BAR
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filters -->
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Search box -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                            Background="White" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" BorderThickness="0" Padding="0,6"
                                     FontSize="13" VerticalAlignment="Center"
                                     Style="{StaticResource FormTextBox}">
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <!-- Priority filter -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="Priority:" VerticalAlignment="Center" Margin="0,0,5,0"
                                   Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding FilterPriorities}"
                                  SelectedItem="{Binding FilterPriority}"
                                  Style="{StaticResource FormComboBox}" Width="110">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisp}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Status filter -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,5,0"
                                   Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding FilterStatuses}"
                                  SelectedItem="{Binding FilterStatus}"
                                  Style="{StaticResource FormComboBox}" Width="120">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisp}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Clear filters -->
                    <Button Content="✕ Clear Filters"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource GhostButton}"
                            FontSize="12" Padding="10,5"
                            Visibility="{Binding IsFiltered, Converter={StaticResource BoolVis}}"/>
                </WrapPanel>

                <!-- Add button -->
                <Button Grid.Column="1"
                        Content="＋  Log New Issue"
                        Command="{Binding OpenAddPanelCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="16,7" FontSize="13"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 3 — MAIN CONTENT (List + Side Panel)
        ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">

            <!-- ── Issue DataGrid ─────────────────────────────── -->
            <Border Margin="16,14,16,14" Style="{StaticResource CardPanel}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table header row -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,10" CornerRadius="6,6,0,0">
                        <Grid>
                            <TextBlock Style="{StaticResource H2}">
                                <Run Text="Issues"/>
                                <Run Text=" "/>
                                <Run Text="(" Foreground="{StaticResource TextMutedBrush}"/>
                                <Run Text="{Binding FilteredIssues.Count}" Foreground="{StaticResource AmberBrush}" FontWeight="Bold"/>
                                <Run Text=")" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="✏️ Edit"
                                        Command="{Binding OpenEditPanelCommand}"
                                        Style="{StaticResource GhostButton}"
                                        IsEnabled="{Binding HasSelectedIssue}"
                                        FontSize="12" Padding="10,4" Margin="0,0,8,0"/>
                                <Button Content="🗑 Delete"
                                        Command="{Binding DeleteIssueCommand}"
                                        Style="{StaticResource DangerButton}"
                                        IsEnabled="{Binding HasSelectedIssue}"
                                        FontSize="12" Padding="10,4"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredIssues}"
                              SelectedItem="{Binding SelectedIssue}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              SelectionMode="Single"
                              RowStyle="{StaticResource IssueRow}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              BorderThickness="0"
                              Background="White"
                              RowHeaderWidth="0"
                              FontSize="13"
                              FontFamily="Calibri"
                              ColumnHeaderHeight="36">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"   Value="{StaticResource SurfaceBrush}"/>
                                <Setter Property="Foreground"   Value="{StaticResource NavyBrush}"/>
                                <Setter Property="FontWeight"   Value="SemiBold"/>
                                <Setter Property="FontSize"     Value="12"/>
                                <Setter Property="Padding"      Value="12,0"/>
                                <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"        Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <!-- Ref No -->
                            <DataGridTextColumn Header="Ref No." Binding="{Binding ReferenceNumber}" Width="90" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource SteelBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Priority pill -->
                            <DataGridTemplateColumn Header="Priority" Width="90" IsReadOnly="True" SortMemberPath="Priority">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PillBadge}"
                                                Background="{Binding Priority, Converter={StaticResource PrioColor}}"
                                                Margin="8,4">
                                            <TextBlock Text="{Binding Priority, Converter={StaticResource EnumDisp}}"
                                                       Foreground="White" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Status pill -->
                            <DataGridTemplateColumn Header="Status" Width="110" IsReadOnly="True" SortMemberPath="Status">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PillBadge}"
                                                Background="{Binding Status, Converter={StaticResource StatColor}}"
                                                Margin="8,4">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource EnumDisp}}"
                                                       Foreground="White" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Title -->
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Location -->
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Responsible Party -->
                            <DataGridTextColumn Header="Responsible Party" Binding="{Binding ResponsibleParty}" Width="160" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Date Logged -->
                            <DataGridTextColumn Header="Date Logged" Binding="{Binding DateLogged, StringFormat='dd/MM/yyyy'}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Due Date -->
                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat='dd/MM/yyyy'}" Width="100" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── ADD PANEL OVERLAY ──────────────────────────── -->
            <Border HorizontalAlignment="Right"
                    Width="390"
                    Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolVis}}"
                    Style="{StaticResource CardPanel}" Padding="0"
                    Margin="0,14,16,14"
                    Panel.ZIndex="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SidebarHeader}" CornerRadius="6,6,0,0">
                        <Grid>
                            <TextBlock Text="Log New Issue" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="✕" HorizontalAlignment="Right"
                                    Command="{Binding CloseAddPanelCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="White" FontSize="16" Cursor="Hand" Padding="4"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="Title *" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="34"/>

                            <TextBlock Text="Description" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"/>

                            <TextBlock Text="Location" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="34"/>

                            <TextBlock Text="Responsible Party" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormResponsibleParty, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="34"/>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Priority" Style="{StaticResource Label}"/>
                                    <ComboBox ItemsSource="{Binding PriorityValues}"
                                              SelectedItem="{Binding FormPriority}"
                                              Style="{StaticResource FormComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDisp}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Status" Style="{StaticResource Label}"/>
                                    <ComboBox ItemsSource="{Binding StatusValues}"
                                              SelectedItem="{Binding FormStatus}"
                                              Style="{StaticResource FormComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDisp}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Date Logged" Style="{StaticResource Label}"/>
                                    <DatePicker SelectedDate="{Binding FormDateLogged}"
                                                FontSize="13" Height="34" BorderBrush="{StaticResource BorderBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Due Date" Style="{StaticResource Label}"/>
                                    <DatePicker SelectedDate="{Binding FormDueDate}"
                                                FontSize="13" Height="34" BorderBrush="{StaticResource BorderBrush}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Remarks / Notes" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormRemarks, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CloseAddPanelCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,0,10,0" Padding="14,7"/>
                            <Button Content="💾  Save Issue" Command="{Binding AddIssueCommand}"
                                    Style="{StaticResource AccentButton}" Padding="14,7"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── EDIT PANEL OVERLAY ─────────────────────────── -->
            <Border HorizontalAlignment="Right"
                    Width="390"
                    Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BoolVis}}"
                    Style="{StaticResource CardPanel}" Padding="0"
                    Margin="0,14,16,14"
                    Panel.ZIndex="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SidebarHeader}" CornerRadius="6,6,0,0"
                            Background="{StaticResource SteelBrush}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Edit Issue" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedIssue.ReferenceNumber}"
                                           Foreground="{StaticResource AmberBrush}" FontSize="12"/>
                            </StackPanel>
                            <Button Content="✕" HorizontalAlignment="Right"
                                    Command="{Binding CloseEditPanelCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="White" FontSize="16" Cursor="Hand" Padding="4"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="Title *" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="34"/>

                            <TextBlock Text="Description" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"/>

                            <TextBlock Text="Location" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="34"/>

                            <TextBlock Text="Responsible Party" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormResponsibleParty, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="34"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Priority" Style="{StaticResource Label}"/>
                                    <ComboBox ItemsSource="{Binding PriorityValues}"
                                              SelectedItem="{Binding FormPriority}"
                                              Style="{StaticResource FormComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDisp}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Status" Style="{StaticResource Label}"/>
                                    <ComboBox ItemsSource="{Binding StatusValues}"
                                              SelectedItem="{Binding FormStatus}"
                                              Style="{StaticResource FormComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDisp}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Date Logged" Style="{StaticResource Label}"/>
                                    <DatePicker SelectedDate="{Binding FormDateLogged}"
                                                FontSize="13" Height="34" IsEnabled="False"
                                                BorderBrush="{StaticResource BorderBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Due Date" Style="{StaticResource Label}"/>
                                    <DatePicker SelectedDate="{Binding FormDueDate}"
                                                FontSize="13" Height="34"
                                                BorderBrush="{StaticResource BorderBrush}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Remarks / Notes" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding FormRemarks, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CloseEditPanelCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,0,10,0" Padding="14,7"/>
                            <Button Content="💾  Save Changes" Command="{Binding SaveEditCommand}"
                                    Style="{StaticResource PrimaryButton}" Padding="14,7"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             ROW 4 — STATUS BAR
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="{StaticResource NavyBrush}" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Spinner -->
                <TextBlock Grid.Column="0" Text="⏳ " VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                           Foreground="{StaticResource AmberBrush}" FontSize="12"/>

                <!-- Status message -->
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" FontSize="11" FontFamily="Calibri">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#90A4AE"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- App version -->
                <TextBlock Grid.Column="2" Text="Snagging Tracker v1.0 · Phases 1–5 Complete"
                           Foreground="#455A64" FontSize="10" VerticalAlignment="Center" FontFamily="Calibri"/>
            </Grid>
        </Border>

        <!-- ── Busy overlay ──────────────────────────────────── -->
        <Grid Grid.Row="0" Grid.RowSpan="5"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
              Background="#20000000">
            <Border Background="White" CornerRadius="8" Padding="30,20"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳  " FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontFamily="Calibri"
                               Foreground="{StaticResource NavyBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
