<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:SnaggingTracker.Converters"
                    xmlns:helpers="clr-namespace:SnaggingTracker.Helpers">

    <!-- ═══════════════════════════════════════════════════════════
         CONVERTERS
    ═══════════════════════════════════════════════════════════ -->
    <conv:PriorityToColorConverter   x:Key="PriorityToColor"/>
    <conv:StatusToColorConverter     x:Key="StatusToColor"/>
    <conv:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
    <conv:BoolToVisibilityConverter  x:Key="InverseVisibility">
    </conv:BoolToVisibilityConverter>
    <conv:EnumDisplayConverter       x:Key="EnumDisplay"/>
    <conv:NullToVisibilityConverter  x:Key="NullToVisibility"/>

    <!-- ═══════════════════════════════════════════════════════════
         COLOR PALETTE
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="NavyColor"     >#0D1B2A</Color>
    <Color x:Key="SteelColor"    >#1B4F72</Color>
    <Color x:Key="TealColor"     >#0E6655</Color>
    <Color x:Key="AmberColor"    >#E67E22</Color>
    <Color x:Key="SurfaceColor"  >#F4F6F7</Color>
    <Color x:Key="CardColor"     >#FFFFFF</Color>
    <Color x:Key="BorderColor"   >#D5DBDB</Color>
    <Color x:Key="TextPrimary"   >#1A1A2E</Color>
    <Color x:Key="TextMuted"     >#717D7E</Color>

    <SolidColorBrush x:Key="NavyBrush"    Color="{StaticResource NavyColor}"/>
    <SolidColorBrush x:Key="SteelBrush"   Color="{StaticResource SteelColor}"/>
    <SolidColorBrush x:Key="TealBrush"    Color="{StaticResource TealColor}"/>
    <SolidColorBrush x:Key="AmberBrush"   Color="{StaticResource AmberColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush"    Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="BorderBrush"  Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMuted}"/>

    <!-- ═══════════════════════════════════════════════════════════
         TYPOGRAPHY
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize"   Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource NavyBrush}"/>
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize"   Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource NavyBrush}"/>
    </Style>
    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>
    <Style x:Key="Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin"     Value="0,8,0,3"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         BUTTON STYLES
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource NavyBrush}"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="FontFamily"   Value="Calibri"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Padding"      Value="16,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource SteelBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource AmberBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#D35400"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TealButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource TealBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#0A5245"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="#C0392B"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#A93226"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Foreground"   Value="{StaticResource NavyBrush}"/>
        <Setter Property="FontFamily"   Value="Calibri"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="Padding"      Value="14,7"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TEXTBOX / COMBOBOX
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="FormTextBox" TargetType="TextBox">
        <Setter Property="FontFamily"       Value="Calibri"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="Background"       Value="White"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource SteelBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FormComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily"       Value="Calibri"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="Background"       Value="White"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Height"           Value="34"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         STAT CARD
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background"   Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding"      Value="16,12"/>
        <Setter Property="MinWidth"     Value="110"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         LIST ROW  (DataGrid row style)
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="IssueRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,1"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#EBF5FB"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F8FBFD"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         PILL / BADGE
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PillBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding"      Value="8,2"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         PANEL / CARD
    ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background"   Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding"      Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.09" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar panel header -->
    <Style x:Key="SidebarHeader" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NavyBrush}"/>
        <Setter Property="Padding"    Value="20,14"/>
    </Style>

</ResourceDictionary>
